<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="false"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/nlog-internal.log">

  <!-- NLog 5.x split the ADO.NET target into its own assembly. -->
  <extensions>
    <add assembly="NLog.Web.AspNetCore" />
    <add assembly="NLog.Database" />
  </extensions>

  <targets async="true">
    <!--
      Database target — persists Error and above into the Logs table.
      Connection string is read from appsettings.json at runtime via
      ${configsetting} so dev/staging/prod each use their own DB
      without nlog.config needing to change. We use MySqlConnector
      because that's what Pomelo.EntityFrameworkCore.MySql already
      depends on, so no extra dependency is pulled in.
    -->
    <target xsi:type="Database"
            name="database"
            dbProvider="MySqlConnector.MySqlConnection, MySqlConnector"
            connectionString="${configsetting:item=ConnectionStrings.DefaultConnection}"
            keepConnection="true">
      <commandText>
        INSERT INTO Logs
          (Logged, Level, Message, Logger, Exception, Url, CallSite, MachineName, UserName)
        VALUES
          (@logged, @level, @message, @logger, @exception, @url, @callsite, @machinename, @username);
      </commandText>
      <parameter name="@logged"      layout="${date:format=yyyy-MM-dd HH\:mm\:ss.fff}" />
      <parameter name="@level"       layout="${level}" />
      <parameter name="@message"     layout="${message}" />
      <parameter name="@logger"      layout="${logger}" />
      <parameter name="@exception"   layout="${exception:format=ToString,StackTrace}${newline}${exception:format=Data}" />
      <parameter name="@url"         layout="${aspnet-request-url:IncludeQueryString=true}" />
      <parameter name="@callsite"    layout="${callsite}" />
      <parameter name="@machinename" layout="${machinename}" />
      <!--
        Authenticated user at the moment of the log call. Renders the
        ClaimsPrincipal's Identity.Name. Empty string for unauthenticated
        requests, which gets stored as NULL.
      -->
      <parameter name="@username"    layout="${aspnet-user-identity}" />
    </target>

    <!--
      Console — kept verbose for dev visibility but unrelated to
      what gets persisted to the database.
    -->
    <target xsi:type="Console"
            name="console"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}${onexception:${newline}${exception:format=ToString}}" />
  </targets>

  <rules>
    <!--
      Strip out EF Core's command/query/connection chatter before it
      reaches any target so we don't even consider it for the DB.
    -->
    <logger name="Microsoft.EntityFrameworkCore.*" maxlevel="Info" final="true" />
    <logger name="Microsoft.AspNetCore.*"          maxlevel="Info" final="true" />

    <!--
      DATABASE: errors only. Keeps the Logs table focused on real issues
      worth triaging instead of every health-check ping.
    -->
    <logger name="*" minlevel="Error" writeTo="database" />

    <!--
      Console keeps the regular dev signal.
    -->
    <logger name="*" minlevel="Info" writeTo="console" />
  </rules>
</nlog>
